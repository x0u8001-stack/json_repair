{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "docs",
  "builds": [
    {
      "src": "docs/app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/repair-json",
      "dest": "/docs/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "/docs/$1"
    }
  ]
}
